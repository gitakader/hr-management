generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  fullName      String
  mobileNumber  String    @unique
  password      String
  role          String    @default("applicant")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?
  applications  Application[]
  documents     Document[]
  activityLogs  ActivityLog[]
  permissions   PermissionAssignment[]
  createdPosts  JobPost[]         @relation("JobPostCreator")
}

model Profile {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique
  fullName            String
  fathersName         String   @default("")
  mothersName         String   @default("")
  presentVillage      String   @default("")
  presentPostOffice   String   @default("")
  presentThana        String   @default("")
  presentDistrict     String   @default("")
  permanentVillage    String   @default("")
  permanentPostOffice String   @default("")
  permanentThana      String   @default("")
  permanentDistrict   String   @default("")
  dateOfBirth         String   @default("")
  identityNumber      String   @default("")
  identityType        String   @default("")
  gender              String   @default("")
  nationality         String   @default("Bangladeshi")
  religion            String   @default("")
  maritalStatus       String   @default("")
  signature           String   @default("")
  photo               String   @default("")
  isProfileComplete   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  education  Education[]
  experience Experience[]
  training   Training[]
}

model Education {
  id          Int      @id @default(autoincrement())
  profileId   Int
  examName    String
  groupDept   String   @default("")
  gpaClass    String   @default("")
  passingYear String
  board       String   @default("")
  document    String   @default("")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Experience {
  id          Int      @id @default(autoincrement())
  profileId   Int
  designation String
  department  String   @default("")
  officeName  String
  startDate   String
  endDate     String   @default("")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Training {
  id              Int      @id @default(autoincrement())
  profileId       Int
  trainingName    String
  instituteName   String
  additionalInfo  String   @default("")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model JobPost {
  id              Int      @id @default(autoincrement())
  title           String
  companyName     String
  designation     String
  description     String   @default("")
  pdfNotice       String   @default("")
  applicationDeadline String
  isActive        Boolean  @default(true)
  createdById     Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator        User          @relation("JobPostCreator", fields: [createdById], references: [id])
  applications   Application[]
}

model Application {
  id              Int      @id @default(autoincrement())
  applicationId   String   @unique
  userId          Int
  jobPostId       Int
  status          String   @default("pending")
  comment         String   @default("")
  approvalDate    String   @default("")
  shortlistDate   String   @default("")
  interviewDate   String   @default("")
  rejectionReason String   @default("")
  employeeId      String   @default("")
  joiningDate     String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  jobPost  JobPost  @relation(fields: [jobPostId], references: [id])
  folders  Folder[]
}

model Document {
  id        Int      @id @default(autoincrement())
  userId    Int
  filename  String
  filepath  String
  mimetype  String   @default("")
  size      Int      @default(0)
  category  String   @default("general")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Folder {
  id            Int      @id @default(autoincrement())
  name          String
  applicationId Int?
  parentId      Int?
  isFile        Boolean  @default(false)
  filepath      String   @default("")
  mimetype      String   @default("")
  createdAt     DateTime @default(now())

  application Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  parent      Folder?      @relation("FolderStructure", fields: [parentId], references: [id])
  children    Folder[]     @relation("FolderStructure")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @default("")

  assignments PermissionAssignment[]
}

model PermissionAssignment {
  id           Int      @id @default(autoincrement())
  userId       Int
  permissionId Int
  granted      Boolean  @default(true)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  details   String   @default("")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
